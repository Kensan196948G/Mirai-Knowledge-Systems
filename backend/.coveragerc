[run]
source = blueprints,dal,schemas,app_helpers,password_policy,csrf_protection

[report]
# MS365外部サービス依存コードは実環境なしにテスト不可なため除外
omit =
    dal/ms365.py
    blueprints/ms365.py
    blueprints/ms365_integration.py
    scripts/*
    migrations/*
    */__pycache__/*
    */test_*.py
    setup.py
    conftest.py

# PostgreSQL分岐はユニットテストではJSON路で代替。
# 「_use_postgresql()がTrueの場合」分岐は統合テストで別途カバー。
exclude_lines =
    pragma: no cover
    if self\._use_postgresql\(\):
    def __repr__
    raise NotImplementedError
